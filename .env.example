# ============================================================
# DTI Region 7 — EMS Platform — Root Environment Example
# Copy this to .env and fill in real values for local dev.
# NEVER commit .env to source control.
# ============================================================

# --- Identity Service ----------------------------------------
IDENTITY_SERVICE_URL=http://localhost:3001

# --- Event Service -------------------------------------------
EVENT_SERVICE_URL=http://localhost:3002

# --- Analytics Service (Phase 3) ----------------------------
ANALYTICS_SERVICE_URL=http://localhost:3003

# --- PostgreSQL (Docker Compose local) ----------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dti_ems
POSTGRES_PASSWORD=devpassword123
POSTGRES_DB=dti_ems_dev

# --- Redis (Docker Compose local) ---------------------------
REDIS_URL=redis://localhost:6379

# --- Kafka (Docker Compose local) ---------------------------
KAFKA_BROKERS=localhost:9092

# --- App URLs -----------------------------------------------
PUBLIC_APP_URL=http://localhost:5173
ORGANIZER_APP_URL=http://localhost:5174
ADMIN_APP_URL=http://localhost:5175
DASHBOARD_APP_URL=http://localhost:5176

# --- SMTP (Mailpit local) -----------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM="DTI Region 7 EMS <noreply@dti7-ems.local>"

# --- SMS (leave blank for local dev) -----------------------
SEMAPHORE_API_KEY=

# --- JWT RSA Keys (generate with: node scripts/generate-keys.js)
# These are BASE64-encoded PKCS#8 private key and SPKI public key
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

# --- GCP (leave blank for local dev) -----------------------
GCP_PROJECT_ID=
GCP_REGION=asia-southeast1
GCS_BUCKET_CERTIFICATES=
GCS_BUCKET_REPORTS=

# --- Elasticsearch (Phase 3) --------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# --- Misc ---------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
