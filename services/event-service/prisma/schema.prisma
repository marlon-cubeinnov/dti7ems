// Event Service Prisma schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/event-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  COMPLETED
  CANCELLED

}

enum ParticipantStatus {
  REGISTERED
  TNA_PENDING
  RSVP_CONFIRMED
  ATTENDED
  COMPLETED
  NO_SHOW
  WAITLISTED
  CANCELLED

}

enum DeliveryMode {
  FACE_TO_FACE
  ONLINE
  HYBRID

}

enum CertificateStatus {
  PENDING
  GENERATED
  ISSUED
  REVOKED

}

enum AttendanceMethod {
  QR_SCAN
  MANUAL

}

enum CsfSurveyStatus {
  PENDING
  SUBMITTED
  EXPIRED

}

enum ImpactSurveyStatus {
  SCHEDULED
  PENDING
  SUBMITTED
  EXPIRED

}

enum EventType {
  TRAINING
  EVENT
}

enum StaffRole {
  FACILITATOR
  CO_FACILITATOR
  RESOURCE_PERSON
  REGISTRATION_OFFICER
  LOGISTICS
  DOCUMENTATION
  SECRETARIAT
  IT_SUPPORT
  FINANCE
  OTHER
}

enum TrainingType {
  BUSINESS
  MANAGERIAL
  ORGANIZATIONAL
  ENTREPRENEURIAL
  INTER_AGENCY
  SEMINAR
  FORUM
  CONFERENCE
  TRADE_FAIR
  TRADE_MISSION
  CONSULTATION
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED

}

// ── Models ────────────────────────────────────────────────────────────────────

model Program {
  id          String   @id @default(cuid())
  title       String
  description String?
  sector      String
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  events      Event[]

  @@map("programs")
}

model Event {
  id                   String       @id @default(cuid())
  programId            String?      @map("program_id")

  title                String
  description          String?      @db.Text
  venue                String?
  latitude             Decimal?     @db.Decimal(10, 7)
  longitude            Decimal?     @db.Decimal(10, 7)
  deliveryMode         DeliveryMode @default(FACE_TO_FACE) @map("delivery_mode")
  onlineLink           String?      @map("online_link")

  status               EventStatus  @default(DRAFT)
  maxParticipants      Int?         @map("max_participants")
  registrationDeadline DateTime?    @map("registration_deadline")
  startDate            DateTime     @map("start_date")
  endDate              DateTime     @map("end_date")

  targetSector         String?      @map("target_sector")
  targetRegion         String?      @map("target_region")
  requiresTNA          Boolean      @default(true) @map("requires_tna")

  // References identity-service user IDs (cross-service, no FK)
  organizerId          String       @map("organizer_id")
  programManagerId     String?      @map("program_manager_id")
  // Facilitator assigned after proposal approval (EVENT_ORGANIZER role)
  assignedOrganizerId    String?      @map("assigned_organizer_id")
  assignedOrganizerName  String?      @map("assigned_organizer_name")
  assignedOrganizerEmail String?      @map("assigned_organizer_email")

  coverImageUrl        String?      @map("cover_image_url")

  // Event type: training or general event
  eventType            EventType    @default(TRAINING) @map("event_type")

  // Proposal fields (FM-CT-4)
  trainingType         TrainingType? @map("training_type")
  partnerInstitution   String?      @map("partner_institution")
  background           String?      @db.Text
  objectives           String?      @db.Text
  expectedOutputs      String?      @db.Text @map("expected_outputs")
  learningOutcomes     String?      @db.Text @map("learning_outcomes")
  methodology          String?      @db.Text
  monitoringPlan       String?      @db.Text @map("monitoring_plan")
  proposalStatus       ProposalStatus @default(DRAFT) @map("proposal_status")
  proposalSubmittedAt  DateTime?    @map("proposal_submitted_at")
  proposalReviewedById String?      @map("proposal_reviewed_by_id")
  proposalApprovedById String?      @map("proposal_approved_by_id")
  proposalReviewedAt   DateTime?    @map("proposal_reviewed_at")
  proposalApprovedAt   DateTime?    @map("proposal_approved_at")
  proposalRejectionNote String?     @db.Text @map("proposal_rejection_note")
  approvedProposalUrl  String?      @db.Text @map("approved_proposal_url")  // attachment of signed/approved proposal doc

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  program              Program?     @relation(fields: [programId], references: [id])
  sessions             EventSession[]
  participations       EventParticipation[]
  checklists           EventChecklist[]
  speakers             TrainingSpeaker[]
  postActivityReport              PostActivityReport?
  trainingEffectivenessReport     TrainingEffectivenessReport?
  budgetItems          TrainingBudgetItem[]
  riskItems            TrainingRiskItem[]
  targetGroups         TrainingTargetGroup[]
  staff                EventStaff[]
  proposalAttachments  ProposalAttachment[]
  materials            EventMaterial[]

  @@index([status])
  @@index([startDate])
  @@index([organizerId])
  @@index([assignedOrganizerId])
  @@map("events")
}

model EventSession {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  title       String
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  venue       String?
  speakerName String?  @map("speaker_name")
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  event               Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendanceRecords   AttendanceRecord[]

  @@map("event_sessions")
}

model EventParticipation {
  id               String            @id @default(cuid())
  eventId          String            @map("event_id")
  userId           String            @map("user_id")
  enterpriseId     String?           @map("enterprise_id")
  enterpriseName   String?           @map("enterprise_name")
  status           ParticipantStatus @default(REGISTERED)

  // Denormalized from identity-service at registration time
  participantName  String?           @map("participant_name")
  participantEmail String?           @map("participant_email")

  registeredAt     DateTime          @default(now()) @map("registered_at")
  rsvpConfirmedAt  DateTime?         @map("rsvp_confirmed_at")
  tnaCompletedAt   DateTime?         @map("tna_completed_at")
  completedAt      DateTime?         @map("completed_at")
  notes            String?

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tnaResponse      TNAResponse?
  attendanceRecords AttendanceRecord[]
  certificate      Certificate?
  csfSurveyResponse CsfSurveyResponse?
  impactSurveyResponse ImpactSurveyResponse?

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("event_participations")
}

model TNAResponse {
  id               String   @id @default(cuid())
  participationId  String   @unique @map("participation_id")
  userId           String   @map("user_id")

  // Scores: 0–100
  knowledgeScore   Decimal  @map("knowledge_score") @db.Decimal(5, 2)
  skillScore       Decimal  @map("skill_score")     @db.Decimal(5, 2)
  motivationScore  Decimal  @map("motivation_score") @db.Decimal(5, 2)
  // compositeScore = (knowledge * 0.35) + (skill * 0.40) + (motivation * 0.25)
  compositeScore   Decimal  @map("composite_score") @db.Decimal(5, 2)

  recommendedTrack String?  @map("recommended_track")
  responses        Json     @default("{}")

  submittedAt      DateTime @default(now()) @map("submitted_at")

  participation    EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@map("tna_responses")
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  participationId  String           @map("participation_id")
  sessionId        String           @map("session_id")
  userId           String           @map("user_id")
  method           AttendanceMethod @default(QR_SCAN)
  scannedAt        DateTime         @default(now()) @map("scanned_at")
  scannedByUserId  String?          @map("scanned_by_user_id")

  participation    EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  session          EventSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([participationId, sessionId])
  @@map("attendance_records")
}

model Certificate {
  id               String            @id @default(cuid())
  participationId  String            @unique @map("participation_id")
  userId           String            @map("user_id")
  eventId          String            @map("event_id")
  status           CertificateStatus @default(PENDING)
  storageUrl       String?           @map("storage_url")
  verificationCode String            @unique @map("verification_code")
  generatedAt      DateTime?         @map("generated_at")
  issuedAt         DateTime?         @map("issued_at")

  participation    EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@index([verificationCode])
  @@index([userId])
  @@map("certificates")
}

model CsfSurveyResponse {
  id                   String          @id @default(cuid())
  participationId      String          @unique @map("participation_id")
  eventId              String          @map("event_id")
  userId               String          @map("user_id")
  status               CsfSurveyStatus @default(PENDING)

  // 9 SQD dimensions (1-5 Likert)
  sqd0OverallRating    Int?            @map("sqd0_overall_rating")
  sqd1Responsiveness   Int?            @map("sqd1_responsiveness")
  sqd2Reliability      Int?            @map("sqd2_reliability")
  sqd3AccessFacilities Int?            @map("sqd3_access_facilities")
  sqd4Communication    Int?            @map("sqd4_communication")
  sqd5Costs            Int?            @map("sqd5_costs")
  sqd6Integrity        Int?            @map("sqd6_integrity")
  sqd7Assurance        Int?            @map("sqd7_assurance")
  sqd8Outcome          Int?            @map("sqd8_outcome")

  // Citizen's Charter questions
  cc1Awareness         Int?            @map("cc1_awareness")    // 1-4
  cc2Visibility        Int?            @map("cc2_visibility")   // 1-4
  cc3Usefulness        Int?            @map("cc3_usefulness")   // 1-3

  // Open-ended feedback
  highlightsFeedback   String?         @db.Text @map("highlights_feedback")
  improvementsFeedback String?         @db.Text @map("improvements_feedback")
  commentsSuggestions  String?         @db.Text @map("comments_suggestions")
  reasonsForLowRating  String?         @db.Text @map("reasons_for_low_rating")

  submittedAt          DateTime?       @map("submitted_at")
  expiresAt            DateTime?       @map("expires_at")
  createdAt            DateTime        @default(now()) @map("created_at")

  participation        EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  speakerRatings       CsfSpeakerRating[]

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("csf_survey_responses")
}

model ImpactSurveyResponse {
  id               String             @id @default(cuid())
  participationId  String             @unique @map("participation_id")
  eventId          String             @map("event_id")
  userId           String             @map("user_id")
  status           ImpactSurveyStatus @default(SCHEDULED)

  // Scheduled dispatch date (180 days after event completion)
  scheduledAt      DateTime           @map("scheduled_at")
  dispatchedAt     DateTime?          @map("dispatched_at")

  // Impact ratings 1–5
  knowledgeApplication   Int?         @map("knowledge_application")
  skillImprovement       Int?         @map("skill_improvement")
  businessImpact         Int?         @map("business_impact")
  revenueChange          Int?         @map("revenue_change")
  employeeGrowth         Int?         @map("employee_growth")

  // Open-ended
  successStory           String?      @db.Text @map("success_story")
  challengesFaced        String?      @db.Text @map("challenges_faced")
  additionalSupport      String?      @db.Text @map("additional_support")

  // Quantitative
  revenueChangePct       Decimal?     @map("revenue_change_pct") @db.Decimal(5, 2)
  employeeCountBefore    Int?         @map("employee_count_before")
  employeeCountAfter     Int?         @map("employee_count_after")

  submittedAt            DateTime?    @map("submitted_at")
  expiresAt              DateTime?    @map("expires_at")
  createdAt              DateTime     @default(now()) @map("created_at")

  participation          EventParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  effectivenessEval      TrainingEffectivenessEvaluation?

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("impact_survey_responses")
}

// ── Event Checklist (Planning & Preparation Tracker) ────────────────────────

enum ChecklistItemStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum ChecklistItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventPhase {
  PLANNING
  PREPARATION
  EXECUTION
  POST_EVENT
}

model EventChecklist {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  title       String
  description String?  @db.Text
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]

  @@index([eventId])
  @@map("event_checklists")
}

// ── Training Speakers ──────────────────────────────────────────────────────

model TrainingSpeaker {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  name         String
  organization String?
  topic        String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  event          Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakerRatings CsfSpeakerRating[]

  @@index([eventId])
  @@map("training_speakers")
}

model CsfSpeakerRating {
  id            String @id @default(cuid())
  csfResponseId String @map("csf_response_id")
  speakerId     String @map("speaker_id")
  rating        Int    // 1-5

  csfResponse CsfSurveyResponse @relation(fields: [csfResponseId], references: [id], onDelete: Cascade)
  speaker     TrainingSpeaker   @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([csfResponseId, speakerId])
  @@map("csf_speaker_ratings")
}

model ChecklistItem {
  id               String                @id @default(cuid())
  checklistId      String                @map("checklist_id")
  title            String
  description      String?               @db.Text
  phase            EventPhase            @default(PLANNING)
  status           ChecklistItemStatus   @default(NOT_STARTED)
  priority         ChecklistItemPriority @default(MEDIUM)
  // WBS (Work Breakdown Structure)
  wbsCode          String?               @map("wbs_code")       // e.g. "1.2.3"
  parentItemId     String?               @map("parent_item_id") // self-referencing for hierarchy
  // Multi-assignee: JSON array of { userId, name } objects
  assignees        Json                  @default("[]")
  dueDate          DateTime?             @map("due_date")
  completedAt      DateTime?             @map("completed_at")
  completedBy      String?               @map("completed_by")
  isApplicable     Boolean?              @map("is_applicable")
  orderIndex       Int                   @default(0) @map("order_index")
  notes            String?               @db.Text
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  checklist        EventChecklist        @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  comments         ChecklistComment[]
  children         ChecklistItem[]       @relation("ChecklistItemParent")
  parent           ChecklistItem?        @relation("ChecklistItemParent", fields: [parentItemId], references: [id])

  @@index([checklistId])
  @@index([status])
  @@index([phase])
  @@index([parentItemId])
  @@map("checklist_items")
}

model ChecklistComment {
  id            String   @id @default(cuid())
  itemId        String   @map("item_id")
  authorId      String   @map("author_id")
  authorName    String   @map("author_name")
  content       String   @db.Text
  attachmentUrl String?  @map("attachment_url") @db.Text
  linkUrl       String?  @map("link_url") @db.Text
  linkLabel     String?  @map("link_label")
  createdAt     DateTime @default(now()) @map("created_at")

  item          ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("checklist_comments")
}

// ── Post-Activity Report (FM-CT-6) ─────────────────────────────────────────

model PostActivityReport {
  id                        String    @id @default(cuid())
  eventId                   String    @unique @map("event_id")
  title                     String
  dateConducted             String    @map("date_conducted")
  venue                     String
  highlightsOutcomes        String?   @db.Text @map("highlights_outcomes")
  fundUtilizationNotes      String?   @db.Text @map("fund_utilization_notes")
  csfAssessmentObservations String?   @db.Text @map("csf_assessment_observations")
  improvementOpportunities  String?   @db.Text @map("improvement_opportunities")
  status                    String    @default("DRAFT")
  preparedById              String?   @map("prepared_by_id")
  reviewedById              String?   @map("reviewed_by_id")
  approvedById              String?   @map("approved_by_id")
  datePrepared              DateTime? @map("date_prepared")
  dateReviewed              DateTime? @map("date_reviewed")
  dateApproved              DateTime? @map("date_approved")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  event             Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  beneficiaryGroups PARBeneficiaryGroup[]

  @@map("post_activity_reports")
}

model PARBeneficiaryGroup {
  id                 String @id @default(cuid())
  reportId           String @map("report_id")
  sectorGroup        String @map("sector_group")
  maleCount          Int    @default(0) @map("male_count")
  femaleCount        Int    @default(0) @map("female_count")
  seniorCitizenCount Int    @default(0) @map("senior_citizen_count")
  pwdCount           Int    @default(0) @map("pwd_count")
  edtLevel           String? @map("edt_level")
  actualCount        Int    @default(0) @map("actual_count")

  report PostActivityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("par_beneficiary_groups")
}

// ── Training Effectiveness Evaluation (FM-CT-5) ─────────────────────────────

model TrainingEffectivenessEvaluation {
  id                        String    @id @default(cuid())
  impactSurveyResponseId    String    @unique @map("impact_survey_response_id")
  appliedLearnings          Boolean?  @map("applied_learnings")
  benefitIncreasedSales     Boolean   @default(false) @map("benefit_increased_sales")
  benefitSalesPct           Decimal?  @db.Decimal(5,2) @map("benefit_sales_pct")
  benefitIncreasedProfit    Boolean   @default(false) @map("benefit_increased_profit")
  benefitProfitPct          Decimal?  @db.Decimal(5,2) @map("benefit_profit_pct")
  benefitCostReduction      Boolean   @default(false) @map("benefit_cost_reduction")
  benefitCostPct            Decimal?  @db.Decimal(5,2) @map("benefit_cost_pct")
  benefitNewMarkets         Boolean   @default(false) @map("benefit_new_markets")
  benefitProductivity       Boolean   @default(false) @map("benefit_productivity")
  benefitManpowerWelfare    Boolean   @default(false) @map("benefit_manpower_welfare")
  benefitStandardizedOp     Boolean   @default(false) @map("benefit_standardized_op")
  benefitBookkeeping        Boolean   @default(false) @map("benefit_bookkeeping")
  benefitImprovedMgmt       Boolean   @default(false) @map("benefit_improved_mgmt")
  benefitSetupBusiness      Boolean   @default(false) @map("benefit_setup_business")
  benefitExpandBusiness     Boolean   @default(false) @map("benefit_expand_business")
  benefitEnhancedCapacity   Boolean   @default(false) @map("benefit_enhanced_capacity")
  benefitAdoptTechnology    Boolean   @default(false) @map("benefit_adopt_technology")
  benefitInnovation         Boolean   @default(false) @map("benefit_innovation")
  benefitNoComplaints       Boolean   @default(false) @map("benefit_no_complaints")
  benefitOthers             String?   @map("benefit_others")
  needsProductDevelopment   Boolean   @default(false) @map("needs_product_development")
  needsLoanAdvisory         Boolean   @default(false) @map("needs_loan_advisory")
  needsOthers               String?   @map("needs_others")
  futureTrainingRequests    String?   @db.Text @map("future_training_requests")
  trainingEffective         Boolean?  @map("training_effective")
  ineffectiveReason         String?   @db.Text @map("ineffective_reason")
  respondentDesignation     String?   @map("respondent_designation")
  respondentCompany         String?   @map("respondent_company")
  dateAccomplished          DateTime? @map("date_accomplished")
  createdAt                 DateTime  @default(now()) @map("created_at")

  impactSurveyResponse ImpactSurveyResponse @relation(fields: [impactSurveyResponseId], references: [id], onDelete: Cascade)

  @@map("training_effectiveness_evaluations")
}

// ── Training Effectiveness Report (FM-CT-5 Approval Workflow) ─────────────

model TrainingEffectivenessReport {
  id                    String    @id @default(cuid())
  eventId               String    @unique @map("event_id")
  status                String    @default("DRAFT")
  observations          String?   @db.Text
  preparedById          String?   @map("prepared_by_id")
  reviewedById          String?   @map("reviewed_by_id")
  approvedById          String?   @map("approved_by_id")
  submittedToMaaById    String?   @map("submitted_to_maa_by_id")
  datePrepared          DateTime? @map("date_prepared")
  dateReviewed          DateTime? @map("date_reviewed")
  dateApproved          DateTime? @map("date_approved")
  dateSubmittedToMaa    DateTime? @map("date_submitted_to_maa")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  event                 Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("training_effectiveness_reports")
}

// ── Training Budget Items (FM-CT-4 Proposal) ───────────────────────────────

model TrainingBudgetItem {
  id               String  @id @default(cuid())
  eventId          String  @map("event_id")
  item             String
  unitCost         Decimal @map("unit_cost") @db.Decimal(12, 2)
  quantity         Int     @default(1)
  estimatedAmount  Decimal @map("estimated_amount") @db.Decimal(12, 2)
  sourceOfFunds    String? @map("source_of_funds")
  actualSpent      Decimal? @map("actual_spent") @db.Decimal(12, 2)
  orderIndex       Int     @default(0) @map("order_index")
  createdAt        DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("training_budget_items")
}

// ── Training Risk Register (FM-CT-4 Proposal) ──────────────────────────────

model TrainingRiskItem {
  id                String  @id @default(cuid())
  eventId           String  @map("event_id")
  riskDescription   String  @map("risk_description") @db.Text
  actionPlan        String? @map("action_plan") @db.Text
  actionDate        DateTime? @map("action_date")
  responsiblePerson String?  @map("responsible_person")
  effectiveness     String?  @db.Text
  orderIndex        Int     @default(0) @map("order_index")
  createdAt         DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("training_risk_items")
}

// ── Training Target Groups (FM-CT-4 Proposal) ──────────────────────────────

model TrainingTargetGroup {
  id                    String   @id @default(cuid())
  eventId               String   @map("event_id")
  edtLevel              String?  @map("edt_level")
  sectorGroup           String   @map("sector_group")
  estimatedParticipants Int      @default(0) @map("estimated_participants")
  orderIndex            Int      @default(0) @map("order_index")
  createdAt             DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("training_target_groups")
}

// ── Pre-Proposal TNA (Training Needs Assessment conducted before proposal) ──

enum PreProposalTnaStatus {
  DRAFT
  FINALIZED
}

enum TnaRespondentType {
  INDIVIDUAL
  BUSINESS_OWNER
  ORGANIZATION
  GOVERNMENT
}

// A Pre-Proposal TNA is created by a Program Manager BEFORE writing the proposal.
// Findings are used to justify the training design (background/rationale).
model PreProposalTna {
  id             String               @id @default(cuid())
  title          String
  sector         String
  targetRegion   String?              @map("target_region")
  description    String?              @db.Text
  status         PreProposalTnaStatus @default(DRAFT)
  conductedBy    String               @map("conducted_by")       // userId of Program Manager
  conductedByName String?             @map("conducted_by_name")
  conductedAt    DateTime?            @map("conducted_at")
  summary        String?              @db.Text                   // overall findings summary
  recommendedTopics String?           @db.Text @map("recommended_topics")
  linkedEventId  String?              @map("linked_event_id")    // set when TNA is used in a proposal

  // Step 1 – Quick Screening (Yes/No)
  screenQ1       Boolean              @default(false) @map("screen_q1") // Performance gap vs. industry standards
  screenQ2       Boolean              @default(false) @map("screen_q2") // Gap caused by lack of KSA
  screenQ3       Boolean              @default(false) @map("screen_q3") // Training will improve business outcomes
  screenQ4       Boolean              @default(false) @map("screen_q4") // Aligns with DTI priorities / MSME roadmap
  screenQ5       Boolean              @default(false) @map("screen_q5") // Demand from multiple MSMEs / sector-wide

  // Step 2 – Scoring Matrix (1=Low, 5=High)
  scorePerformanceGap    Int?         @map("score_performance_gap")    // 1=No gap; 5=Critical gap
  scoreSkillDeficiency   Int?         @map("score_skill_deficiency")   // 1=Not training-related; 5=Entirely training-related
  scoreBusinessRelevance Int?         @map("score_business_relevance") // 1=No impact; 5=Critical impact
  scoreUrgency           Int?         @map("score_urgency")            // 1=Not urgent; 5=Immediate
  scoreDemandMsmes       Int?         @map("score_demand_msmes")       // 1=Individual; 5=Nationwide/sector-wide

  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  respondents    TnaRespondent[]

  @@index([conductedBy])
  @@index([sector])
  @@index([status])
  @@map("pre_proposal_tnas")
}

// One respondent row per survey collected during the TNA
model TnaRespondent {
  id               String            @id @default(cuid())
  tnaId            String            @map("tna_id")
  respondentType   TnaRespondentType @default(INDIVIDUAL) @map("respondent_type")
  name             String?
  organization     String?
  sector           String?
  region           String?

  // Need areas — how important is training in each area? (1 = Not Needed, 5 = Very High Need)
  needKnowledge    Int               @default(3) @map("need_knowledge")    // 1-5
  needSkills       Int               @default(3) @map("need_skills")       // 1-5
  needAttitude     Int               @default(3) @map("need_attitude")     // 1-5

  // Preferred topics (free-text, comma-separated or JSON)
  preferredTopics  String?           @db.Text @map("preferred_topics")

  // Preferred delivery
  preferredMode    String?           @map("preferred_mode")   // FACE_TO_FACE | ONLINE | HYBRID
  preferredSchedule String?          @map("preferred_schedule") // WEEKDAY | WEEKEND | FLEXIBLE

  // Open feedback
  currentChallenges String?          @db.Text @map("current_challenges")
  additionalNeeds   String?          @db.Text @map("additional_needs")

  createdAt        DateTime          @default(now()) @map("created_at")

  tna              PreProposalTna    @relation(fields: [tnaId], references: [id], onDelete: Cascade)

  @@index([tnaId])
  @@map("tna_respondents")
}

// ── Event Staff (multi-person assignment with roles) ────────────────────────

model EventStaff {
  id           String    @id @default(cuid())
  eventId      String    @map("event_id")
  userId       String    @map("user_id")       // identity-service user ID
  userName     String    @map("user_name")     // denormalized display name
  userEmail    String?   @map("user_email")
  role         StaffRole @default(FACILITATOR)
  notes        String?   @db.Text
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedBy   String    @map("assigned_by")   // userId of assigner

  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, role])
  @@index([eventId])
  @@index([userId])
  @@map("event_staff")
}

// ── Proposal Attachments ────────────────────────────────────────────────────

model ProposalAttachment {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  category     String   @default("GENERAL")     // GENERAL | TNA_REFERENCE
  fileName     String   @map("file_name")
  fileUrl      String   @db.Text @map("file_url")
  fileSize     Int?     @map("file_size")       // bytes
  mimeType     String?  @map("mime_type")
  description  String?  @db.Text
  uploadedBy   String   @map("uploaded_by")    // userId
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("proposal_attachments")
}

model EventMaterial {
  id          String    @id @default(cuid())
  eventId     String    @map("event_id")
  title       String
  description String?   @db.Text
  driveUrl    String    @db.Text @map("drive_url")
  uploadedBy  String    @map("uploaded_by")    // userId
  expiresAt   DateTime  @map("expires_at")     // event.endDate + 15 days
  isExpired   Boolean   @default(false) @map("is_expired")
  expiredAt   DateTime? @map("expired_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([expiresAt])
  @@map("event_materials")
}
