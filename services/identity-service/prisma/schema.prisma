// This is your Prisma schema file for the Identity Service.
// Run: pnpm --filter identity-service db:generate
// Run: pnpm --filter identity-service db:migrate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  PARTICIPANT
  ENTERPRISE_REPRESENTATIVE
  PROGRAM_MANAGER
  EVENT_ORGANIZER
  DIVISION_CHIEF
  REGIONAL_DIRECTOR
  PROVINCIAL_DIRECTOR
  SYSTEM_ADMIN
  SUPER_ADMIN

}

enum UserStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DEACTIVATED

}

enum EnterpriseStage {
  IDEATION
  VALIDATION
  GROWTH
  EXPANSION
  MATURITY_EXIT
}

// MSME CPMS — Category / Level of Assistance
enum MsmeLevel {
  LEVEL_0       // Would be or Potential Entrepreneurs
  LEVEL_1       // Nurturing Startup
  LEVEL_1_1     // Unregistered
  LEVEL_1_2     // Partially Registered
  LEVEL_2       // Growing Enterprises (Registered)
  LEVEL_3       // Expanding Enterprises (Registered)
  LEVEL_4       // Sustaining Enterprises (Registered)
  CEASED        // Ceased Operations
}

enum FormOfOrganization {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  ASSOCIATION
  CORPORATION
  COOPERATIVE
  WORKERS_RURAL_ASSOCIATION
  ONE_PERSON_CORPORATION
  FRANCHISE
}

enum AssetSizeClassification {
  MICRO   // Up to Php3,000,000
  SMALL   // Php3,000,001 to Php15,000,000
  MEDIUM  // Php15,000,001 to Php100,000,000
  LARGE   // More than Php100,000,000
}

enum BusinessActivity {
  MANUFACTURING_PRODUCING
  WHOLESALING_TRADING
  RETAILING_TRADING
  EXPORTING
  IMPORTING
  SERVICE
}

enum EdtLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum RipplesStage {
  STAGE_5
  STAGE_6
  STAGE_7
}

enum SmeraStage {
  STAGE_1
  STAGE_2
  STAGE_3
  STAGE_4
}

enum DigitalizationLevel {
  LEVEL_0  // No use of digital tools
  LEVEL_1  // Basic
  LEVEL_2  // Intermediate
  LEVEL_3  // Advanced
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

// ── Models ────────────────────────────────────────────────────────────────────

model UserProfile {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(PARTICIPANT)
  status       UserStatus @default(PENDING_VERIFICATION)

  // Personal info
  firstName        String  @map("first_name")
  lastName         String  @map("last_name")
  middleName       String? @map("middle_name")
  mobileNumber     String? @map("mobile_number")

  // Address
  region           String?
  province         String?
  cityMunicipality String? @map("city_municipality")
  barangay         String?

  // DTI Demographics (FM-CT-2A, FM-CSF-ACT)
  nameSuffix             String? @map("name_suffix")
  sex                    String? // MALE, FEMALE
  birthdate              DateTime? @map("birth_date")
  ageBracket             String? @map("age_bracket") // AGE_19_OR_LOWER, AGE_20_TO_34, AGE_35_TO_49, AGE_50_TO_64, AGE_65_OR_HIGHER
  employmentCategory     String? @map("employment_category") // SELF_EMPLOYED, EMPLOYED_GOVT, EMPLOYED_PRIVATE, GENERAL_PUBLIC
  socialClassification   String? @map("social_classification") // ABLED, PWD, FOUR_PS, YOUTH, SENIOR_CITIZEN, INDIGENOUS_PERSON, OFW, OTHERS
  clientType             String? @map("client_type") // CITIZEN, BUSINESS, GOVERNMENT

  // Professional
  jobTitle                String? @map("job_title")
  industryClassification  String? @map("industry_classification")

  // DPA RA 10173 consent
  dpaConsentGiven Boolean   @default(false) @map("dpa_consent_given")
  dpaConsentAt    DateTime? @map("dpa_consent_at")

  // Verification
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  verifyToken      String?   @map("verify_token")
  verifyTokenExp   DateTime? @map("verify_token_exp")

  // Password reset
  resetToken    String?   @map("reset_token")
  resetTokenExp DateTime? @map("reset_token_exp")

  // Employee invite
  inviteToken    String?   @map("invite_token")
  inviteTokenExp DateTime? @map("invite_token_exp")
  invitedBy      String?   @map("invited_by")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Relations
  enterpriseProfiles    EnterpriseProfile[]
  enterpriseMemberships EnterpriseMembership[]
  auditLogs             AuditLog[]

  @@map("user_profiles")
}

model EnterpriseProfile {
  id               String          @id @default(cuid())
  userId           String          @map("user_id")

  // ── Section 1: Client IDs ─────────────────────────────────────────────────
  cpmsIdNumber     String?         @map("cpms_id_number")
  oldCpmsIdNumber  String?         @map("old_cpms_id_number")
  philsysNumber    String?         @map("philsys_number")
  tinNumber        String?         @map("tin_number")
  dtiKonekIdNumber String?         @map("dti_konek_id_number")

  // ── Section 2: MSME Status / Level ───────────────────────────────────────
  msmeLevel            MsmeLevel?  @map("msme_level")
  levelZeroCategories  String[]    @map("level_zero_categories") // for LEVEL_0 multi-select
  businessIsRegistered Boolean?    @map("business_is_registered")

  // ── Section 3: Business Registration ─────────────────────────────────────
  businessName           String          @map("business_name")
  registeredBusinessName String?         @map("registered_business_name")
  tradeName              String?         @map("trade_name")
  dateOfRegistration     DateTime?       @map("date_of_registration")
  registrationNo         String?         @map("registration_no")     // primary DTI/SEC reg no
  ipoRegistrationNumber  String?         @map("ipo_registration_number")

  // Registrations & Licenses (JSON arrays)
  // businessRegistrations: [{ type: 'DTI'|'SEC'|'DOLE'|'CDA'|'OTHERS', registrationNo: string, expiry: string|null }]
  businessRegistrations  Json?           @map("business_registrations")
  // businessPermits: [{ type: 'BUSINESS_PERMIT'|'BIR'|'FDA'|'BMBE'|'OTHERS', permitNo: string, expiry: string|null }]
  businessPermits        Json?           @map("business_permits")
  // secondaryLicenses: [{ type: 'ICC'|'ISO'|'PRODUCT_STANDARD'|'OTHERS', licenseNo: string, expiry: string|null }]
  secondaryLicenses      Json?           @map("secondary_licenses")

  // ── Section 4: Business Address ───────────────────────────────────────────
  houseNo          String?         @map("house_no")
  streetName       String?         @map("street_name")
  streetAddress    String?         @map("street_address")  // legacy combined field
  barangay         String?
  district         String?
  cityMunicipality String?         @map("city_municipality")
  province         String?
  region           String?
  zipCode          String?         @map("zip_code")
  latitude         Decimal?        @db.Decimal(10, 7)
  longitude        Decimal?        @db.Decimal(10, 7)

  // ── Section 5: Business Contact Details ──────────────────────────────────
  businessEmail    String?         @map("business_email")
  businessPhone    String?         @map("business_phone")
  businessFax      String?         @map("business_fax")
  websiteUrl       String?         @map("website_url")
  socialMediaFacebook  String?     @map("social_media_facebook")
  socialMediaInstagram String?     @map("social_media_instagram")
  socialMediaLinkedIn  String?     @map("social_media_linkedin")
  socialMediaOthers    String?     @map("social_media_others")
  // ecommercePlatforms: [{ platform: 'SHOPEE'|'LAZADA'|'APEC'|'GO_LOKAL'|'OTHERS', url: string }]
  ecommercePlatforms   Json?       @map("ecommerce_platforms")

  // ── Section 6: Business Profile ───────────────────────────────────────────
  description            String?              @db.Text
  yearEstablished        Int?                 @map("year_established")
  formOfOrganization     FormOfOrganization?  @map("form_of_organization")
  assetSizeClassification AssetSizeClassification? @map("asset_size_classification")
  primaryBusinessActivity   BusinessActivity? @map("primary_business_activity")
  secondaryBusinessActivity BusinessActivity? @map("secondary_business_activity")

  // PSIC
  psicSection  String?  @map("psic_section")
  psicDivision String?  @map("psic_division")
  psicGroup    String?  @map("psic_group")

  priorityIndustry            String?  @map("priority_industry")
  industryClusterEnhancement  String?  @map("industry_cluster_enhancement")
  industrySector              String   @map("industry_sector")
  industryTags                String[] @map("industry_tags")
  tradeAssociationAffiliations String[] @map("trade_association_affiliations")

  // Legacy stage field (kept for backward compat)
  stage            EnterpriseStage @default(VALIDATION)

  // ── Section 7: Business Owner Information ─────────────────────────────────
  ownerPrefix           String?    @map("owner_prefix")
  ownerFirstName        String?    @map("owner_first_name")
  ownerMiddleName       String?    @map("owner_middle_name")
  ownerLastName         String?    @map("owner_last_name")
  ownerSuffix           String?    @map("owner_suffix")
  ownerBirthdate        DateTime?  @map("owner_birthdate")
  ownerCitizenship      String?    @map("owner_citizenship")
  ownerSex              String?    @map("owner_sex")              // MALE | FEMALE
  ownerCivilStatus      String?    @map("owner_civil_status")     // SINGLE | MARRIED | WIDOWED | LEGALLY_SEPARATED
  ownerSocialClassification String? @map("owner_social_classification")
  ownerHouseNo          String?    @map("owner_house_no")
  ownerStreetName       String?    @map("owner_street_name")
  ownerBarangay         String?    @map("owner_barangay")
  ownerDistrict         String?    @map("owner_district")
  ownerCityMunicipality String?    @map("owner_city_municipality")
  ownerProvince         String?    @map("owner_province")
  ownerRegion           String?    @map("owner_region")
  ownerZipCode          String?    @map("owner_zip_code")

  // ── Section 8: Business Trackers ──────────────────────────────────────────
  edtLevel            EdtLevel?           @map("edt_level")
  ripplesStage        RipplesStage?       @map("ripples_stage")
  smeraStage          SmeraStage?         @map("smera_stage")
  digitalizationLevel DigitalizationLevel? @map("digitalization_level")
  // digitalToolsUsed: [{ category: 'COLLABORATIVE_SUITES'|'COMMUNICATION'|'PROJECT_MGMT'|'ACCOUNTING_PAYROLL'|'CMS'|'CYBERSECURITY'|'CLOUD_STORAGE'|'FINTECH', toolName: string }]
  digitalToolsUsed    Json?               @map("digital_tools_used")
  hasEmail            Boolean?            @map("has_email")
  hasFacebook         Boolean?            @map("has_facebook")

  // ── Section 9: Business Financial Structure ───────────────────────────────
  initialCapitalization      Decimal?  @map("initial_capitalization") @db.Decimal(18, 2)
  initialCapitalizationYear  Int?      @map("initial_capitalization_year")
  authorizedCapital          Decimal?  @map("authorized_capital") @db.Decimal(18, 2)
  subscribedCapital          Decimal?  @map("subscribed_capital") @db.Decimal(18, 2)
  paidUpCapital              Decimal?  @map("paid_up_capital") @db.Decimal(18, 2)
  assetSizeRange             String?   @map("asset_size_range")
  domesticSales              Decimal?  @map("domestic_sales") @db.Decimal(18, 2)
  exportSales                Decimal?  @map("export_sales") @db.Decimal(18, 4)
  annualRevenue              Decimal?  @map("annual_revenue") @db.Decimal(15, 2)

  // ── Section 10: Market Access ──────────────────────────────────────────────
  // domesticMarkets: [{ productService: string, region: string, province: string }]
  domesticMarkets  Json?  @map("domestic_markets")
  // exportMarkets: [{ dateStarted: string|null, productService: string, country: string, tradeBoc: string }]
  exportMarkets    Json?  @map("export_markets")
  // importMarkets: [{ dateStarted: string|null, productCommodity: string, country: string }]
  importMarkets    Json?  @map("import_markets")

  // ── Section 11: Product / Services Line ───────────────────────────────────
  // productLines: [{ productService: string, description: string, majorRawMaterials: string, annualProductionCapacity: string, year: number|null, valueVolume: string, unitOfMeasure: string }]
  productLines  Json?  @map("product_lines")

  // ── Section 12: Product/Service Certifications ────────────────────────────
  // productCertifications: [{ certificationType: string, certifyingBody: string, expiryDate: string|null }]
  productCertifications  Json?  @map("product_certifications")

  // ── Section 13: Employment Statistics ─────────────────────────────────────
  ftAbledMale        Int?  @map("ft_abled_male")
  ftAbledFemale      Int?  @map("ft_abled_female")
  ftDiffAbledMale    Int?  @map("ft_diff_abled_male")
  ftDiffAbledFemale  Int?  @map("ft_diff_abled_female")
  ftIndigenousMale   Int?  @map("ft_indigenous_male")
  ftIndigenousFemale Int?  @map("ft_indigenous_female")
  ftSeniorMale       Int?  @map("ft_senior_male")
  ftSeniorFemale     Int?  @map("ft_senior_female")
  ptAbledMale        Int?  @map("pt_abled_male")
  ptAbledFemale      Int?  @map("pt_abled_female")
  ptDiffAbledMale    Int?  @map("pt_diff_abled_male")
  ptDiffAbledFemale  Int?  @map("pt_diff_abled_female")
  ptIndigenousMale   Int?  @map("pt_indigenous_male")
  ptIndigenousFemale Int?  @map("pt_indigenous_female")
  ptSeniorMale       Int?  @map("pt_senior_male")
  ptSeniorFemale     Int?  @map("pt_senior_female")

  // ── Tracking ───────────────────────────────────────────────────────────────
  employeeCount    Int?            @map("employee_count")  // legacy; use ft/pt fields above
  isVerified       Boolean         @default(false) @map("is_verified")
  isPubliclyListed Boolean         @default(false) @map("is_publicly_listed")

  profileUpdateDue       Boolean   @default(true)  @map("profile_update_due")
  profileLastUpdatedAt   DateTime? @map("profile_last_updated_at")
  profileLastUpdatedBy   String?   @map("profile_last_updated_by")
  annualUpdateYear       Int?      @map("annual_update_year")

  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  user             UserProfile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberships      EnterpriseMembership[]
  updateLogs       EnterpriseUpdateLog[]

  @@map("enterprise_profiles")
}

model EnterpriseUpdateLog {
  id           String   @id @default(cuid())
  enterpriseId String   @map("enterprise_id")
  updatedBy    String   @map("updated_by")      // userId
  updatedAt    DateTime @default(now()) @map("updated_at")
  updateYear   Int      @map("update_year")     // calendar year of this update
  updateType   String   @map("update_type")     // FIRST_LOGIN | ANNUAL | VOLUNTARY
  changedFields Json    @map("changed_fields")  // array of { field, oldValue, newValue }
  snapshotAfter Json    @map("snapshot_after")  // full enterprise data after update
  ipAddress    String?  @map("ip_address")
  notes        String?  @db.Text

  enterprise   EnterpriseProfile @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@index([updatedBy])
  @@index([updateYear])
  @@index([updatedAt])
  @@map("enterprise_update_logs")
}

model EnterpriseMembership {
  id           String         @id @default(cuid())
  enterpriseId String         @map("enterprise_id")
  userId       String         @map("user_id")
  role         MembershipRole @default(MEMBER)
  status       String         @default("ACTIVE") @map("status") // PENDING | ACTIVE | INACTIVE | REJECTED
  isActive     Boolean        @default(true) @map("is_active")
  joinedAt     DateTime       @default(now()) @map("joined_at")

  enterprise   EnterpriseProfile @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user         UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, userId])
  @@index([userId])
  @@map("enterprise_memberships")
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  action     String
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  oldData    Json?     @map("old_data")
  newData    Json?     @map("new_data")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Roles & Permissions ──────────────────────────────────────────────────────

model RoleConfig {
  id          String   @id @default(cuid())
  name        String   @unique                // matches UserRole enum value e.g. "PARTICIPANT"
  label       String                          // human-readable e.g. "Participant"
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")  // system roles can't be deleted
  isActive    Boolean  @default(true)  @map("is_active")
  createdAt   DateTime @default(now())  @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  permissions RolePermission[]

  @@map("role_configs")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique                // e.g. "events.create", "users.manage"
  label       String                          // e.g. "Create Events"
  group       String                          // grouping category e.g. "Events", "Users"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  roles       RolePermission[]

  @@index([group])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by")

  role         RoleConfig @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ── System Settings ──────────────────────────────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String?  @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}
