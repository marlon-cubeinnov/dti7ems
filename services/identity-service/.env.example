// Identity Service .env — copy from .env.example, fill in values

# PostgreSQL
DATABASE_URL="postgresql://dti_ems:devpassword123@localhost:5432/dti_ems_dev?schema=identity_schema"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (run: node ../../scripts/generate-keys.js)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# App
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# SMTP (Mailpit local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM="DTI Region 7 EMS <noreply@dti7-ems.local>"
APP_URL=http://localhost:5173

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=identity-service
KAFKA_GROUP_ID=identity-service-group

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
