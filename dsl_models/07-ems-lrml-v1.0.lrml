  }
  */

  // ─────────────────────────────────────────────
  // STYLE DEFINITIONS
  // ─────────────────────────────────────────────

  style DTI_ReportStyle {
    primary_color    = "#003087" ;
    accent_color     = "#F58220" ;
    font_family      = "'Inter', 'Helvetica Neue', Arial, sans-serif" ;
    heading_weight   = 700 ;
    body_weight      = 400 ;
    page_background  = "#FFFFFF" ;
    header_logo      = "gcs://dti-ems-avatars/dti-region7-logo.png" ;
    footer_text      = "Department of Trade and Industry — Region 7 | Generated by DTI EMS v1.0" ;
    date_format      = "MMMM D, YYYY" ;
    currency_symbol  = "₱" ;
    locale           = "en-PH" ;
  }

}
