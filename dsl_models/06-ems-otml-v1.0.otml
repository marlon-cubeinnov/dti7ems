// ============================================================
// OTML v1.7 — Operational & Service Infrastructure Model
// System  : DTI Region 7 — EMS & Industry Dashboard
// Version : 1.1
// Date    : 2026-04-16
// Updated : 2026-04-17
// Purpose : Model cloud-hosted microservices, message brokers,
//           pipelines, monitoring, and operational workflows
//           using OTML's service-oriented metaphor.
//
// STATUS  : Reflects Phase 1–2 implementation (local dev).
//           Phase 3 nodes are annotated but not implemented.
// ============================================================

namespace DTI.EMS.Operations version "1.0.0" ;

import "./01-ems-dbml-v1.0.dbml" as domain ;
import "./02-ems-sdml-v1.0.sdml" as security ;
import "./05-ems-blml-v1.0.blml" as logic ;

// ─────────────────────────────────────────────
// SYSTEM BLOCK — Cloud Platform Overview
// ─────────────────────────────────────────────

SystemBlock "DTI_EMS_Platform" {
  domain : "Event Management & Industry Dashboard" ;
  area   : "Local Docker Compose (dev) → GCP (production, Phase 3)" ;

  // ── Active Nodes (Phase 1–2) ──
  node : IdentityServiceNode ;     // Port 3011
  node : EventServiceNode ;        // Port 3012 — includes surveys, certificates, PDF generation
  node : NotificationServiceNode ; // Port 3013 — BullMQ + Resend email + Semaphore SMS
  node : PostgreSQLNode ;          // Port 5433 (Docker)
  node : RedisNode ;               // Port 6379 (localhost)

  // ── Phase 3 Nodes (NOT IMPLEMENTED) ──
  // node : AnalyticsServiceNode ;
  // node : DirectoryServiceNode ;
  // node : ETLPipelineNode ;
  // node : APIGatewayNode ;       // Kong Gateway
  // node : MessageBrokerNode ;    // Apache Kafka
  // node : ElasticsearchNode ;
  // node : ObjectStorageNode ;    // GCS
  // node : MonitoringNode ;       // OpenTelemetry + Grafana
}

// ─────────────────────────────────────────────
// SERVICE NODES (Node Blocks)
// ─────────────────────────────────────────────

node IdentityServiceNode {
  runtime     : "Node.js 20 LTS (Fastify v5)" ;
  container   : "Docker (dev) → Cloud Run (prod, Phase 3)" ;
  port        : 3011 ;
  replicas    : 1 ;
  endpoints : [
    "POST /auth/register"
    "POST /auth/login"
    "POST /auth/logout"
    "POST /auth/refresh-token"
    "GET  /users/me"
    "GET  /users/:id"
    "PATCH /users/:id"
    "GET  /enterprises"
    "POST /enterprises"
    "PATCH /enterprises/:id"
  ]
  auth        : "JWT RS256 (15-min access + 7-day refresh, firstName/lastName in payload)" ;
  password_hash : "Argon2" ;
  token_blacklist : "Redis" ;
  orm         : "Prisma" ;
}

node EventServiceNode {
  runtime     : "Node.js 20 LTS (Fastify v5)" ;
  container   : "Docker (dev) → Cloud Run (prod, Phase 3)" ;
  port        : 3012 ;
  replicas    : 1 ;
  endpoints : [
    // Event CRUD
    "GET    /events"
    "GET    /events/:id"
    "GET    /events/mine"
    "POST   /events"
    "PATCH  /events/:id"
    "PATCH  /events/:id/status"
    // Sessions
    "GET    /events/:id/sessions"
    "POST   /events/:id/sessions"
    "DELETE /events/:id/sessions/:sessionId"
    // Participants
    "GET    /events/:id/participants"
    "GET    /events/:id/participants/export"   // CSV download
    // Participations
    "POST   /participations/events/:eventId/register"
    "GET    /participations/events/:eventId/me"
    "GET    /participations/me"
    "GET    /participations/:id"
    "POST   /participations/:id/tna"
    "POST   /participations/:id/confirm-rsvp"
    // QR & Attendance
    "GET    /participations/:id/qr"             // Permanent HMAC token
    "POST   /participations/attendance/scan"
    "POST   /participations/:id/manual-checkin"
    "GET    /participations/:id/attendance"
    // Certificates (PDFKit — no Puppeteer/document-service)
    "POST   /certificates/:participationId/issue"
    "POST   /certificates/bulk-issue/:eventId"
    "GET    /certificates/my"
    "GET    /certificates/:participationId"
    "PATCH  /certificates/:participationId/revoke"
    "GET    /certificates/verify/:code"         // Public, no auth
    "GET    /certificates/:participationId/pdf" // PDFKit landscape A4 stream
    // CSF Surveys (integrated — no separate survey-service)
    "POST   /surveys/events/:eventId/csf"
    "GET    /surveys/events/:eventId/csf/me"
    "GET    /surveys/events/:eventId/csf/results"
  ]
  orm         : "Prisma" ;
  pdf_engine  : "PDFKit (inline generation, no Puppeteer)" ;
  qr_engine   : "qrcode npm (server-side)" ;
  notifies    : "HTTP fire-and-forget to NotificationServiceNode via notify.ts" ;
  triggers_sent : [
    "registration-confirmation (on POST /register)"
    "bulk-csf-invite (1h delay after event → COMPLETED)"
    "certificate-issued (on certificate issue)"
  ]
}

// SurveyServiceNode — REMOVED
// Survey functionality (CSF) is integrated into EventServiceNode.
// See EventServiceNode.endpoints for /surveys/* routes.

node NotificationServiceNode {
  runtime     : "Node.js 20 LTS (Fastify v5 + BullMQ workers)" ;
  container   : "Docker (dev) → Cloud Run Jobs (prod, Phase 3)" ;
  port        : 3013 ;
  replicas    : 1 ;
  queue_backend : "Redis via BullMQ (queues: mail, sms)" ;
  channels : [
    "Email (Resend API — dry-run when RESEND_API_KEY missing)"
    "SMS   (Semaphore PH API — dry-run when SEMAPHORE_API_KEY missing)"
  ]
  // No Kafka — receives work via HTTP trigger endpoints from event-service
  trigger_endpoints : [
    "POST /triggers/registration-confirmation"
    "POST /triggers/rsvp-reminder"
    "POST /triggers/bulk-csf-invite"
    "POST /triggers/certificate-issued"
    "POST /triggers/test-email"
  ]
  workers : [
    "email.worker.ts — processes 'mail' queue via Resend API"
    "sms.worker.ts   — processes 'sms' queue via Semaphore API"
  ]
  templates : [
    "registration-confirmation (HTML email)"
    "rsvp-reminder (HTML email)"
    "csf-survey-invite (HTML email)"
    "certificate-issued (HTML email)"
  ]
}

// DocumentServiceNode — REMOVED
// PDF certificate generation uses PDFKit inside EventServiceNode.
// See EventServiceNode endpoint: GET /certificates/:participationId/pdf

// ─────────────────────────────────────────────
// PHASE 3 NODES (NOT IMPLEMENTED)
// ─────────────────────────────────────────────

