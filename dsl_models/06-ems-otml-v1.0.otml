// ─────────────────────────────────────────────
// INFRASTRUCTURE NODES (Active)
// ─────────────────────────────────────────────

node PostgreSQLNode {
  technology   : "PostgreSQL 15" ;
  hosting      : "Docker (dev, port 5433) → GCP Cloud SQL (prod, Phase 3)" ;
  database     : "dti_ems_dev" ;
  replicas     : 1 ;
  orm          : "Prisma (separate clients per service)" ;
  schemas : [
    "identity-service Prisma schema"
    "event-service Prisma schema (events, sessions, participations, certificates, CSF surveys)"
  ]
  // Phase 3: backup_policy, encryption, connection_pool, PostGIS, TimescaleDB
}

node RedisNode {
  technology   : "Redis 7 (localhost:6379)" ;
  hosting      : "Local (dev) → GCP Memorystore (prod, Phase 3)" ;
  purpose : [
    "BullMQ job queue (NotificationService: mail + sms queues)"
    "JWT token blacklist (Identity Service)"
  ]
  maxmemory_policy : "allkeys-lru" ;
}

