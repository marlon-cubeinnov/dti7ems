// ─────────────────────────────────────────────
// DEVICE CLASSES (Participant endpoints)
// ─────────────────────────────────────────────

device_class WebBrowser {
  description : "Desktop or laptop web browser (Chrome, Firefox, Safari, Edge)" ;
  capabilities : [ "camera", "notifications", "downloads", "localStorage" ] ;
  target_services : [ web-public ] ; // Single React SPA with role-based routing
}

device_class MobileDevice {
  description : "Smartphone (iOS / Android) — primary QR scanner device" ;
  capabilities : [ "camera-qr", "gps", "push-notifications", "touch" ] ;
  target_services : [ web-public ] ; // QR scanner in /organizer/* routes
  note : "QR scanner uses device camera via browser MediaDevices API (no native app required)" ;
}

// ─────────────────────────────────────────────
// WORKFLOWS (Operational)
// ─────────────────────────────────────────────

workflow_block DeploymentWorkflow {
  description : "CI/CD pipeline for all microservices" ;
  steps : [
    "Developer pushes to feature branch"
    "GitHub Actions: lint + unit tests + integration tests"
    "PR review and approval (minimum 1 reviewer)"
    "Merge to main → Docker build → push to GCP Artifact Registry"
    "Cloud Build: deploy to staging environment"
    "Automated E2E tests against staging"
    "Manual approval gate for production deploy"
    "Blue/green deployment via Cloud Run traffic splitting"
    "OpenTelemetry trace validation post-deploy"
    "Rollback: Cloud Run traffic revert to previous revision (< 2 min)"
  ]
}

workflow_block DatabaseMigrationWorkflow {
  description : "Safe schema migration process for PostgreSQL" ;
  steps : [
    "Developer creates migration file via Prisma migrate dev"
    "Migration reviewed in PR"
    "Dry-run against staging DB (Prisma migrate deploy -- dry-run)"
    "Maintenance window scheduled (low-traffic: 2 AM–4 AM PHT)"
    "Apply migration: Prisma migrate deploy"
    "Smoke tests run against migrated DB"
    "Rollback script committed alongside migration"
  ]
}

workflow_block IncidentResponseWorkflow {
  description : "Operational incident response procedure" ;
  steps : [
    "Alert fires → on-call engineer paged via PagerDuty"
    "Engineer acknowledges within 15 minutes"
    "Initial triage: identify affected service from Grafana dashboard"
    "Mitigation: scale up replicas / rollback / bypass affected service"
    "Incident channel created in Slack (auto-created by PagerDuty)"
    "Data Protection Officer notified if PII breach suspected (within 72h per DPA)"
    "Root cause analysis (RCA) documented within 48 hours"
    "Postmortem published to internal wiki"
    "Control added to SDML / BLML if gap identified"
  ]
}

workflow_block ETLRunWorkflow {
  description : "Nightly ETL pipeline execution procedure" ;
  steps : [
    "Cloud Scheduler triggers ETLPipelineNode at 02:00 PHT"
    "Extract: query event_schema and survey_schema for new records since last run"
    "Transform: deduplicate profiles, calculate activity scores, normalize metrics"
    "Load: upsert into analytics_schema"
    "Aggregate: compute regional heatmap data, timeseries snapshots"
    "Sync: re-index updated enterprises in Elasticsearch"
    "Data quality checks: row counts, null checks, schema validation"
    "Emit ems.etl.run_complete event → Dashboard cache invalidated"
    "Log run metadata (duration, rows processed, errors)"
    "Alert on failure → P1 incident created"
  ]
}

workflow_block BackupRecoveryWorkflow {
  description : "Disaster recovery and backup validation procedure" ;
  steps : [
    "Automated daily snapshot: Cloud SQL → GCS (cross-region replication)"
    "Weekly PITR test restore to isolated test environment"
    "Monthly full DR drill: restore all services from backup in isolated VPC"
    "RTO target: 4 hours | RPO target: 24 hours"
    "Backup integrity verified by automated hash check"
  ]
}

// ─────────────────────────────────────────────
// CONDITION BLOCKS (Operational gates)
// ─────────────────────────────────────────────

condition_block ProductionDeployGate {
  all_tests_pass       == true ;
  staging_e2e_pass     == true ;
  manual_approval      == true ;
  description : "All conditions must be true before Cloud Run traffic shift to production" ;
}

condition_block ETLSuccessGate {
  row_count_matches    == true ;
  null_check_pass      == true ;
  schema_valid         == true ;
  description : "ETL must pass all data quality gates before emitting run_complete event" ;
}

condition_block ExportApprovalGate {
  supervisor_approved  == true ;
  purpose_logged       == true ;
  recipient_logged     == true ;
  description : "All conditions must be met before generating bulk export file" ;
}

// ─────────────────────────────────────────────
// POLICY BLOCKS (Operational)
// ─────────────────────────────────────────────

policy_block DataRetentionPolicy {
  description : "Data lifecycle and retention rules per DPA and DTI records management" ;
  rules : [
    "PII in UserProfile: retained for 7 years after last activity, then anonymized"
    "AuditLog records: retained for 7 years (immutable, no delete)"
    "EventParticipation records: retained for 7 years"
    "ImpactDataPoint records: retained indefinitely (aggregate national data)"
    "Exported reports: deleted from storage after 24 hours"
    "JWT refresh tokens: expire after 7 days"
    "Notification logs: retained for 1 year"
    "ETL run logs: retained for 90 days"
  ]
}

policy_block ScalingPolicy {
  description : "Auto-scaling and capacity planning rules" ;
  rules : [
    "Scale out EventService when CPU > 70% for 2 consecutive minutes"
    "Scale out NotificationService when BullMQ queue depth > 500 jobs"
    "Scale out AnalyticsService when response time P95 > 2 seconds"
    "Never scale below min_instances (availability during off-peak)"
    "Registration surge handling: pre-scale EventService before published event registration opens"
  ]
}

policy_block SecretsRotationPolicy {
  description : "Secret and credential rotation schedule" ;
  rules : [
    "JWT signing keys: rotate every 90 days (blue/green key rotation)"
    "Database passwords: rotate every 180 days via GCP Secret Manager"
    "SMTP API keys: rotate every 180 days"
    "QR token HMAC secret: rotate every 365 days (coordinated with event cycle)"
    "All secrets stored in GCP Secret Manager — no hardcoded values in code"
  ]
}

// ─────────────────────────────────────────────
// HISTORIAN (Metrics time-series)
// ─────────────────────────────────────────────

historian_block OperationalMetrics {
  description : "Key operational metrics tracked over time" ;
  metrics : [
    "EventService.requests_per_second"
    "EventService.p95_latency_ms"
    "EventService.pdf_generation_time_ms"
    "IdentityService.auth_success_rate"
    "NotificationService.delivery_success_rate"
    "NotificationService.queue_depth"
    "PostgreSQL.active_connections"
    "Redis.queue_depth"
  ]
  retention_days : 365 ;
  storage : PostgreSQLNode ;
  // Phase 3: extension : "TimescaleDB" ;
}

// ─────────────────────────────────────────────
// CBM PIPELINE (Condition-Based Monitoring)
// ─────────────────────────────────────────────

cbm_pipeline ServiceHealthPipeline {
  description : "Continuous health monitoring pipeline for all services" ;
  checks : [
    "HTTP health endpoint /healthz returns 200 every 30 seconds"
    "PostgreSQL connection pool utilization < 80%"
    "Redis memory usage < 75%"
    "BullMQ queue depth < 500 (mail + sms queues)"
  ]
  // Phase 3: add Kafka consumer heartbeat, ETL timestamp, Elasticsearch checks
  on_anomaly : "log alert and emit warning" ;
  on_failure : "trigger IncidentResponseWorkflow" ;
}

// ─────────────────────────────────────────────
// META
// ─────────────────────────────────────────────

meta_block ProjectMeta {
  name        : "DTI Region 7 EMS & Industry Dashboard" ;
  version     : "1.1.0" ;
  env         : "development (local Docker Compose)" ;
  cloud       : "GCP (Phase 3 — primary region: asia-southeast1)" ;
  iac_tool    : "Docker Compose (dev) → Terraform (Phase 3)" ;
  container_orchestration : "Docker Compose (dev) → GCP Cloud Run (Phase 3)" ;
  ci_cd       : "Manual (dev) → GitHub Actions (Phase 3)" ;
  source_control : "GitHub (private organization repository)" ;
  team_size   : "5-8 engineers (1 TL, 2-3 FE, 2 BE, 1 DevOps, 1 QA)" ;
  contact     : "dti-region7-ict@dti.gov.ph" ;
}
