        columns = [ legal_name, type, stage, region, verification_status, activity_score ]
      }
      component VerifyEnterpriseBtn       { }
      component LinkProfileToEnterpriseBtn { }
    }
  }

  view ReportsView {
    label  = "Reports & Data Export" ;
    layout = AuthShellLayout ;

    uses entity domain.SurveyContext.SurveyResponse ;
    uses entity domain.SurveyContext.ImpactDataPoint ;
