      component ReportTypePicker      { types = [ EventCompletion, ImpactSummary, AuditLog, BeneficiaryCSV ] ; }
      component DateRangePicker       { }
      component RegionScopePicker     { }
      component ReportPreviewPanel    { }
      component DownloadReportBtn     { approval_required = true ; }
    }
  }

  view AuditLogView {
    label  = "Audit Log Viewer" ;
    layout = AuthShellLayout ;

    uses entity domain.IdentityContext.AuditLog ;

    slot main {
      component AuditLogFilters       { filters = [ actor_id, action, target_type, date_range ] ; }
      component AuditDataTable        { entity = domain.IdentityContext.AuditLog ; }
      component ExportAuditBtn        { roles = [ super_admin ] ; }
    }
  }

  view SystemSettingsView {
    label  = "System Settings" ;
    layout = AuthShellLayout ;

    slot main {
      component SMTPConfigForm              { }
      component SMSGatewayConfigForm        { }
      component NotificationTemplateEditor  { }
      component SurveyTemplateManager       { entity = domain.SurveyContext.SurveyTemplate ; }
      component SaveSettingsBtn             { }
    }
  }
  */

  // ─────────────────────────────────────────────
  // INDUSTRY DASHBOARD VIEWS (Phase 3 — NOT IMPLEMENTED)
  // ─────────────────────────────────────────────

  /*

  view IndustryPublicOverviewView {
    label  = "Industry Dashboard — Public Overview" ;
    layout = AuthShellLayout ;

    slot main {
      component SectorHighlightCards     { }
      component EnterpriseGrowthChart    { entity = domain.IdentityContext.EnterpriseProfile ; }
      component RegionalHeatmapWidget    { }
      component ExportersByRegionChart   { }
      component ProgramImpactSummary     { entity = domain.SurveyContext.ImpactDataPoint ; }
    }
  }

  view EcosystemMapView {
    label  = "Ecosystem Map — Geospatial View" ;
    layout = MapLayout ;

