  // ─────────────────────────────────────────────
  // FEATURES
  // ─────────────────────────────────────────────

  feature EventDiscovery {
    label = "Event Discovery & Listing" ;
    use view EventListView ;
    use view EventDetailView ;
    use view PublicHomeView ;
  }

  feature RegistrationCapture {
    label = "Participant Registration & TNA" ;
    use view RegistrationFormView ;
    use view TNAFormView ;
    use view RSVPConfirmationView ;
    use logic PreFillProfileLogic ;
    use logic TNAScoringLogic ;
  }

  feature DirectoryBrowsing {
    label = "Public Enterprise Directory" ;
    use view DirectoryView ;
    use logic GeoFilterLogic ;
  }

  feature ParticipantSelfService {
    label = "Participant Profile & History" ;
    use view ParticipantDashboardView ;
    use view MyProfileView ;
    use view MyEnterpriseView ;
    use view MyEventsView ;
  }

  feature SurveyParticipation {
    label = "CSF and Impact Survey Participation" ;
    use view SurveyResponseView ;
    use logic SurveyDispatchLogic ;
  }

  feature CertificateAccess {
    label = "Certificate Download" ;
    use view MyCertificatesView ;
  }

  feature EventLifecycleManagement {
    label = "Event Creation and Workflow Management" ;
    use view OrganizerDashboardView ;
    use view EventManagementView ;
    use view ParticipantListView ;
  }

  feature AttendanceTracking {
    label = "QR Code Attendance Scanning" ;
    use view QRScannerView ;
    use logic QRScanLogic ;
  }

  feature CSFCollection {
    label = "CSF Survey Results and Certificate Management" ;
    use view CSFResultsView ;
    use view CertificateManagementView ;
    use logic CertificateGenerationLogic ;
  }

  feature UserGovernance {
    label = "User Account Management and RBAC" ;
    use view UserManagementView ;
    use view AuditLogView ;
  }

  feature EnterpriseGovernance {
    label = "Enterprise Profile Verification and Management" ;
    use view EnterpriseManagementView ;
  }

  feature ReportingAndCompliance {
    label = "Reporting, Export Approvals, and Audit" ;
    use view ReportsView ;
    use view AuditLogView ;
    use logic ExportApprovalLogic ;
  }

  feature SystemConfiguration {
    label = "System Settings and Integration Config" ;
    use view SystemSettingsView ;
  }

  feature PublicIndustryAnalytics {
    label = "Public Sector Overview and Directory" ;
    use view IndustryPublicOverviewView ;
    use view EcosystemMapView ;
    use view DirectoryView ;
  }

  feature InternalImpactTracking {
    label = "Internal Longitudinal Impact Analytics" ;
    use view ImpactTrackingView ;
    use view ETLStatusView ;
  }

  feature PolicyPlanningTools {
    label = "Policy Planning and Sector Gap Analysis" ;
    use view EcosystemMapView ;
  }

  // ─────────────────────────────────────────────
  // UI STRINGS
  // ─────────────────────────────────────────────

  ui-string-set EnglishPH {
    register_cta          = "Register for this Event" ;
    rsvp_confirm_heading  = "You're In! See You There." ;
    tna_intro             = "Help us customize this training for you. This assessment takes 5 minutes." ;
    checkin_success       = "Attendance confirmed! Welcome." ;
    survey_csf_subject    = "How was the training? Share your feedback." ;
    survey_impact_subject = "6 Months Since the Program — How's Your Business?" ;
    dpa_consent_label     = "I consent to DTI Region 7 collecting and processing my personal data in accordance with RA 10173 (Data Privacy Act of 2012)." ;
    cert_download_label   = "Download Certificate of Participation" ;
  }

}
