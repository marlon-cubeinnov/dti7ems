  // ─────────────────────────────────────────────
  // FLOWS (User Journeys)
  // ─────────────────────────────────────────────

  flow PublicRegistrationFlow {
    label = "Public User Registration & Event Sign-Up" ;

    step BrowseEvents      { view = EventListView ; }
    step ViewEventDetail   { view = EventDetailView ; }
    step FillRegistration  { view = RegistrationFormView ; }
    step CompleteTNA       { view = TNAFormView ; condition = "event.requires_tna == true" ; }
    step ReceiveConfirmation { view = RSVPConfirmationView ; }
    step AwaitEvent        { label = "Async: Email reminders sent 1 week prior, 1 day prior" ; }
  }

  flow AttendanceFlow {
    label = "Event Day — Attendance Capture" ;

    step SelectSession   { view = QRScannerView ; }
    step ScanQRCode      { view = QRScannerView ; logic = QRScanLogic ; }
    step CheckInConfirm  { view = QRScannerView ; component = CheckInSuccessToast ; }
    step PostEvent       { label = "Async: CSF email sent 1 hour after event ends" ; }
  }

  flow CSF_SurveyFlow {
    label = "CSF Survey Submission" ;

    step ReceiveCSFEmail { label = "Participant receives email link (automated, 1 hour post-event)" ; }
    step OpenSurveyLink  { view = SurveyResponseView ; }
    step SubmitCSFForm   { view = SurveyResponseView ; logic = SurveyDispatchLogic ; }
    step ViewCompletion  { label = "Confirmation screen. Certificate generation triggered." ; }
  }

  flow ImpactSurveyFlow {
    label = "6-Month Impact Survey Flow" ;

    step Trigger6MonthReminder { label = "Automated scheduler fires 6 months after event completion" ; }
    step ReceiveImpactEmail    { label = "Participant receives email link" ; }
    step OpenImpactSurvey      { view = SurveyResponseView ; }
    step SubmitImpactData      { view = SurveyResponseView ; logic = SurveyDispatchLogic ; }
    step DashboardUpdate       { label = "Async: Enterprise activity score and dashboard metrics updated" ; }
  }

  flow EnterpriseDiscoveryFlow {
    label = "Startup Discovery — Registration to Directory" ;

    step RegisterForEvent    { flow = PublicRegistrationFlow ; }
    step LinkEnterprise      { view = RegistrationFormView ; component = EnterpriseLinkerStep ; }
    step EnterpriseAppears   { view = DirectoryView ; label = "Enterprise visible in public directory (after verification)" ; }
    step ImpactVerification  { flow = ImpactSurveyFlow ; label = "Dashboard updated with verified badge after 6-month survey" ; }
  }

  flow AdminUserManagementFlow {
    label = "Admin User Lifecycle Management" ;

    step ViewUsers         { view = UserManagementView ; }
    step InviteOrFind      { view = UserManagementView ; component = InviteUserBtn ; }
    step SetRole           { view = UserManagementView ; component = UserDataTable ; }
    step SuspendOrActivate { view = UserManagementView ; component = UserStatusToggle ; }
    step AuditChanges      { view = AuditLogView ; }
  }

  // ─────────────────────────────────────────────
  // APPS
  // ─────────────────────────────────────────────

  // All "apps" below run as a SINGLE web-public React SPA (port 5173)
  // with role-based routing. Modeled separately for conceptual clarity.

  app EMS_PublicApp {
    label = "DTI EMS — Public Portal (in web-public)" ;
    channel use PublicPortalChannel ;
    flow    use PublicRegistrationFlow ;
    layout  use PublicShellLayout ;
    theme   use DTI_Theme ;
    feature use EventDiscovery ;
    feature use RegistrationCapture ;
    feature use DirectoryBrowsing ;
    setting  env = "production" ;
  }

  app EMS_ParticipantApp {
    label = "DTI EMS — Participant Portal (in web-public)" ;
    channel use ParticipantChannel ;
    layout  use AuthShellLayout ;
    theme   use DTI_Theme ;
    feature use ParticipantSelfService ;
    feature use SurveyParticipation ;
    feature use CertificateAccess ;
    setting  env = "production" ;
    setting  auth_required = true ;
  }

  app EMS_OrganizerApp {
    label = "DTI EMS — Organizer Console (in web-public)" ;
    channel use OrganizerChannel ;
    layout  use AuthShellLayout ;
    theme   use DTI_Theme ;
    feature use EventLifecycleManagement ;
    feature use AttendanceTracking ;
    feature use CSFCollection ;
    setting  env = "production" ;
    setting  auth_required = true ;
    setting  min_role = "event_organizer" ;
  }

  // Phase 3: EMS_AdminApp and IndustryDashboardApp
  /*
